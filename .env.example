# Server
PORT=3456
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ndjoula_licences

# Auth
API_SECRET=your-api-secret-for-desktop-app
ADMIN_TOKEN=your-admin-bearer-token

# PayDunya
PAYDUNYA_MASTER_KEY=your-master-key
PAYDUNYA_PRIVATE_KEY=your-private-key
PAYDUNYA_PUBLIC_KEY=your-public-key
PAYDUNYA_TOKEN=your-paydunya-token
PAYDUNYA_MODE=test

# App
LICENCE_PRICE=5000
LICENCE_DURATION_DAYS=30
SERVER_URL=http://localhost:3456
